# =====================================================
# CORE APP SETTINGS
# =====================================================
APP_NAME=Newsroom Clipper MVP
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# =====================================================
# AI PROVIDER CONFIGURATION
# This section controls which AI/transcription backend is used.
# Current defaults use local/self-hosted components.
#
# To switch providers later:
# 1) Update the *_PROVIDER variables below.
# 2) Add credentials for the target provider.
# 3) Implement/select the matching provider class in backend/app/providers.
# =====================================================
AI_ANALYSIS_PROVIDER=ollama
TRANSCRIPTION_PROVIDER=whisper_local
CLIP_EXTRACTION_PROVIDER=ffmpeg

# Local Ollama endpoint (external service, not dockerized in this project)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# Local Whisper model options: tiny, base, small, medium, large-v3
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Chunking and analysis settings
TRANSCRIPT_CHUNK_SIZE=1200
TRANSCRIPT_CHUNK_OVERLAP=150
MAX_SUGGESTED_CLIPS=8
ANALYSIS_TIMEOUT_SECONDS=120

# =====================================================
# DATABASE / QUEUE
# =====================================================
POSTGRES_USER=clipper
POSTGRES_PASSWORD=clipper
POSTGRES_DB=clipper_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_URL=postgresql+psycopg2://clipper:clipper@postgres:5432/clipper_db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =====================================================
# STORAGE
# =====================================================
STORAGE_PATH=/storage
UPLOADS_DIR=/storage/uploads
TRANSCRIPTS_DIR=/storage/transcripts
CLIPS_DIR=/storage/clips
CAPTIONS_DIR=/storage/captions

# =====================================================
# FRONTEND
# =====================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# =====================================================
# OPTIONAL FUTURE CLOUD CREDENTIALS
# Keep blank unless you switch to cloud APIs.
# =====================================================
OPENAI_API_KEY=
CLAUDE_API_KEY=
DEEPGRAM_API_KEY=
